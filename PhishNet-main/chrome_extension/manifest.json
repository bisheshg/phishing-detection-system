{
  "name": "PhishNet",
  "version": "2.0.0",
  "description": "Real-time phishing detection — know before you click.",
  "manifest_version": 3,
  "author": "PhishNet",

  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:8800/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishNet — Phishing Detector"
  }
}
