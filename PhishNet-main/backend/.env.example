# MongoDB Connection URI
MONGO_URL=your_mongodb_connection_string_here

# JWT Secret for authentication tokens
# Use a strong, random secret (at least 32 characters)
JWT=your_very_strong_random_jwt_secret_key_here_1234567890

# Cloudinary API Credentials (optional - only if using image uploads)
cloud_name=your_cloudinary_cloud_name
api_key=your_cloudinary_api_key
api_secret=your_cloudinary_api_secret

# Gmail Credentials for sending emails (e.g., alerts)
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=your_gmail_app_password  # Use App Password, NOT your regular password!

# Email recipients for domainPage alerts (comma-separated)
ALERT_RECIPIENTS=alert1@example.com,alert2@example.com

# Razorpay Payment Gateway Credentials
KEY_ID=your_razorpay_key_id
KEY_SECRET=your_razorpay_key_secret

# Backend server port
# You're now running on 5000, so update this!
PORT=5000

# Node environment (important for conditional logic)
NODE_ENV=development

# Allowed CORS Origins (comma-separated, no spaces after commas)
# You've added localhost:5000 as frontend? But usually frontend is 3000.
# Keep all possible development origins + any production later
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,chrome-extension://eafifecgdjhbdnmpodidiiodfdhgofnh

# Optional: For future production deployment
# PRODUCTION_URL=https://yourdomain.com
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com


