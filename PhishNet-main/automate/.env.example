# Gmail IMAP and SMTP server details
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587

# Gmail credentials for the automation account
# This should be an App Password if 2FA is enabled for your Gmail account
GMAIL_AUTOMATE_USER=your_gmail_email@gmail.com
GMAIL_AUTOMATE_PASS=your_gmail_app_password

# API URL for the phishing analysis backend
AUTOMATE_API_URL=http://localhost:5002/analyze_url

# Interval (in seconds) to check for new emails
CHECK_INTERVAL_SECONDS=60
